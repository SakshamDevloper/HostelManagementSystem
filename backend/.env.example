# ─── Required ───────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from Atlas: Connect → Drivers → copy string
# Replace <password> with the database user's password
MONGODB_URI=mongodb+srv://hms-admin:<password>@cluster0.xxxxx.mongodb.net/hostel-management?retryWrites=true&w=majority

# JWT secret — generate a random 64-char string
# Railway can auto-generate this for you
JWT_SECRET=your-random-secret-here-min-32-chars

# ─── Optional (Railway sets defaults) ──────────────────

# Port — Railway sets PORT automatically, leave commented
# PORT=8080

# Node environment
NODE_ENV=production

# CORS origin — set to your Railway domain once deployed
# CLIENT_URL=https://your-project.up.railway.app
