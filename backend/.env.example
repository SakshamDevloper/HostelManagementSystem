# ─── Required (set these in Railway dashboard) ──────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://hms-admin:<password>@cluster0.xxxxx.mongodb.net/hostel-management?retryWrites=true&w=majority

# JWT secret — generate a random 64-char hex string
# Railway can auto-generate this for you
JWT_SECRET=your-random-secret-here-min-32-chars

# ─── Optional (Railway sets defaults) ──────────────────

# Port — Railway sets PORT automatically, leave unset
# PORT=8080

# Node environment — backend defaults to 'production' if unset
# NODE_ENV=production

# CORS origin — set to your Railway domain for Socket.io CORS
# CLIENT_URL=https://your-project.up.railway.app
