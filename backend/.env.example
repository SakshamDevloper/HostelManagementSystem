# MongoDB (use your Atlas connection string)
MONGODB_URI=mongodb+srv://<user>:<password>@hms-cluster.xxxxx.mongodb.net/hostel-management?retryWrites=true&w=majority

# JWT secret (generate a random string)
JWT_SECRET=your-random-secret-here

# Node environment
NODE_ENV=production

# Port (Railway/Render set this automatically)
PORT=8080

# Frontend URL (for CORS)
CLIENT_URL=https://yourdomain.com
